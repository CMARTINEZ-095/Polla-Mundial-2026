<%- include('partials/header') %>

  <div class="page-heading admin-heading">
    <div>
      <p class="eyebrow">Panel de administrador</p>
      <h1>Administración</h1>
      <p class="muted">Crea partidos, corrige calendario y registra resultados oficiales.</p>
    </div>
  </div>

  <section class="stats-grid admin-stats">
    <div>
      <strong>
        <%= summary.players %>
      </strong>
      <span>Participantes</span>
    </div>

    <div>
      <strong>
        <%= summary.total_matches %>
      </strong>
      <span>Partidos</span>
    </div>

    <div>
      <strong>
        <%= summary.completed_matches %>
      </strong>
      <span>Finalizados</span>
    </div>

    <div>
      <strong>
        <%= summary.total_predictions %>
      </strong>
      <span>Pronósticos</span>
    </div>
  </section>

  <section class="card admin-create-match-card">
    <div class="section-title">
      <div>
        <h2>Agregar partido</h2>
        <p class="muted">Crea un nuevo partido para la fase actual.</p>
      </div>
      <span class="admin-chip">Nuevo encuentro</span>
    </div>

    <form action="/admin/matches" method="post" class="admin-form admin-match-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label>
        Fase / Grupo
        <input type="text" name="group_name" placeholder="">
      </label>

      <label>
        Equipo local
        <input type="text" name="home_team" placeholder="" required>
      </label>

      <label>
        Equipo visitante
        <input type="text" name="away_team" placeholder="" required>
      </label>

      <label>
        Fecha/hora Colombia
        <input type="datetime-local" name="kickoff_at" required>
      </label>

      <div class="admin-create-actions">
        <button class="button primary admin-create-button" type="submit">
          Crear partido
        </button>
      </div>
    </form>
  </section>

  <section class="card table-card admin-matches-card">
    <div class="section-title">
      <div>
        <h2>Partidos cargados</h2>
        <p class="muted">Administra resultados, desempates y edición de partidos.</p>
      </div>

      <span class="admin-chip">
        <%= matches.length %> partidos
      </span>
    </div>

    <div class="table-wrap admin-matches-table-wrap">
      <table class="admin-matches-table">
        <thead>
          <tr>
            <th>Partido</th>
            <th>Marcador oficial / Puntos extra</th>
            <th>Estado</th>
            <th>Editar</th>
            <th>Eliminar</th>
          </tr>
        </thead>

        <tbody>
          <% const colorClasses=[ 'match-color-1' , 'match-color-2' , 'match-color-3' , 'match-color-4'
            , 'match-color-5' , 'match-color-6' , 'match-color-7' , 'match-color-8' ]; %>

            <% matches.forEach((match, index)=> {
              const rowColorClass = colorClasses[index % colorClasses.length];

              let statusText = 'Programado';
              let statusClass = 'admin-status-scheduled';

              if (match.status === 'finished') {
              statusText = 'Finalizado';
              statusClass = 'admin-status-finished';
              } else if (match.status === 'live') {
              statusText = 'En vivo';
              statusClass = 'admin-status-live';
              }

              const kickoffDate = match.kickoff_at
              ? new Date(match.kickoff_at).toLocaleString('es-CO', {
              timeZone: 'America/Bogota',
              day: '2-digit',
              month: '2-digit',
              year: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
              })
              : '';
              %>

                <td class="admin-match-info">
                  <div class="admin-match-title">
                    <strong>
                      <%= match.home_team %>
                    </strong>
                    <span class="admin-vs">vs</span>
                    <strong>
                      <%= match.away_team %>
                    </strong>
                  </div>
                </td>
                </td>

                <td>
                  <form action="/admin/matches/<%= match.id %>/result" method="post"
                    class="inline-result-form admin-result-tiebreak-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="score-admin-box">
                      <input type="number" min="0" max="30" name="home_score"
                        value="<%= match.home_score !== null ? match.home_score : '' %>" placeholder="-">

                      <span class="admin-vs">-</span>

                      <input type="number" min="0" max="30" name="away_score"
                        value="<%= match.away_score !== null ? match.away_score : '' %>" placeholder="-">
                    </div>

                    <div class="tie-break-toggle">

                      <span class="toggle-title">
                        Puntos extra
                      </span>

                      <label class="toggle-button">

                        <input type="checkbox" name="tie_breaker_enabled" class="tie-breaker-checkbox"
                          <%=match.tie_breaker_enabled ? 'checked' : '' %>
                        >

                        <span class="toggle-label"></span>

                      </label>

                    </div>

                    <div class="tie-breaker-fields" style="display:none;">
                      <div class="tie-breaker-title">Puntos extra</div>

                      <label>
                        Goleador
                        <input type="text" name="goal_scorer" placeholder=""
                          value="<%= match.goal_scorer || '' %>">
                      </label>

                      <label>
                        Asistidor
                        <input type="text" name="assist_player" placeholder=""
                          value="<%= match.assist_player || '' %>">
                      </label>
                    </div>

                    <button class="button tiny icon-btn save-icon" type="submit" title="Guardar">
                      💾
                    </button>
                  </form>
                </td>

                <td>
                  <span class="admin-status-pill <%= statusClass %>">
                    <%= statusText %>
                  </span>
                </td>

                <td>
                  <a href="/admin/matches/<%= match.id %>/edit" class="button tiny icon-btn edit-button" title="Editar">
                    ⚙️
                  </a>
                </td>

                <td>
                  <form action="/admin/matches/<%= match.id %>/delete" method="post"
                    onsubmit="return confirm('¿Seguro que deseas eliminar este partido?');">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <button class="button tiny icon-btn danger delete-icon" type="submit" title="Eliminar">
                      🗑️
                    </button>
                  </form>
                </td>
              </tr>

              <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <script>
    document.querySelectorAll(".admin-result-tiebreak-form").forEach((form) => {
      const checkbox = form.querySelector(".tie-breaker-checkbox");
      const fields = form.querySelector(".tie-breaker-fields");

      function toggleFields() {
        fields.style.display = checkbox.checked ? "flex" : "none";
      }

      checkbox.addEventListener("change", toggleFields);
      toggleFields();
    });
  </script>

  <%- include('partials/footer') %>