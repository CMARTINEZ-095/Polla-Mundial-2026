<%- include('partials/header') %>

    <div class="page-heading">
        <div>
            <p class="eyebrow">Consulta los pronósticos de la comunidad</p>
            <h1>Pronósticos de la comunidad</h1>
            <p class="muted">
                Los pronósticos de cada partido se muestran únicamente cuando el encuentro ha comenzado.
            </p>
        </div>

        <div class="actions-row">
            <a class="button secondary" href="/leaderboard">🏆 Tabla</a>
            <a class="button secondary" href="/predictions">👥 Mis pronósticos</a>
        </div>
    </div>

    <div class="community-accordion">
        <% visibleMatches.forEach(({ match, isVisible, predictions })=> {
            const exacts = predictions.filter((p) => Number(p.points) === 3).length;
            const outcomes = predictions.filter((p) => Number(p.points) === 1).length;
            const misses = predictions.filter((p) => Number(p.points) === 0).length;
            %>

            <details class="community-match-card">
                <summary class="community-match-summary">
                    <div class="community-header">
                        <div class="community-header-title">
                            <h2>
                                <%= match.home_team %> vs <%= match.away_team %>
                            </h2>

                            <p class="muted">
                                <%= helpers.formatDateTime(match.kickoff_at) %>
                            </p>

                            <div class="community-match-count">
                                <% if (!isVisible) { %>
                                    <span class="match-stat locked">🔒 Pronósticos ocultos</span>
                                    <% } else { %>
                                        <span class="match-stat">👥 <%= predictions.length %> participantes</span>
                                        <span class="match-stat exact">🟢 <%= exacts %> exactos</span>
                                        <span class="match-stat good">🟡 <%= outcomes %> ganador/empate</span>
                                        <span class="match-stat bad">🔴 <%= misses %> fallaron</span>
                                        <% } %>
                            </div>
                        </div>

                        <div class="community-status">
                            <% if (match.status==='finished' ) { %>
                                <span class="status finished">🔴 Finalizado</span>
                                <% } else if (match.status==='live' ) { %>
                                    <span class="status live">🟢 En vivo</span>
                                    <% } else { %>
                                        <span class="status scheduled">🕒 Pendiente</span>
                                        <% } %>
                        </div>
                    </div>

                    <div class="community-toggle">
                        <span class="toggle-open">Ver</span>
                        <span class="toggle-close">Ocultar</span>
                    </div>
                </summary>

                <div class="community-match-content">

                    <% if (!isVisible) { %>
                        <p class="muted">🔒 Los pronósticos estarán disponibles cuando comience el partido.</p>
                        <% } else if (!predictions.length) { %>
                            <p class="muted">Nadie ha pronosticado este partido todavía.</p>
                            <% } else { %>

                                <div class="community-predictions-list">

                                    <% predictions.forEach((item)=> { %>

                                        <article class="community-prediction-card public-style-card"
                                            data-search-name="<%= String(formatDisplayName(item.user_name)).toLowerCase() %>">

                                            <div class="public-player-name">
                                                <span>Participante</span>
                                                <strong>
                                                    <%= formatDisplayName(item.user_name) %>
                                                </strong>
                                            </div>

                                            <div class="public-prediction-box">
                                                <span class="info-title public-box-title">Pronóstico</span>

                                                <div class="public-score-row">
                                                    <span class="public-team-name">
                                                        <%= match.home_team %>
                                                    </span>

                                                    <span class="public-score-box">
                                                        <%= item.prediction_home_score %>
                                                    </span>

                                                    <span class="public-dash">-</span>

                                                    <span class="public-score-box">
                                                        <%= item.prediction_away_score %>
                                                    </span>

                                                    <span class="public-team-name">
                                                        <%= match.away_team %>
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="match-extra-info public-extra-info">

                                                <div class="official-result-card">
                                                    <span class="info-title">Resultado oficial</span>

                                                    <% if (item.real_home_score===null || item.real_away_score===null) {
                                                        %>
                                                        <strong class="pending-text">Pendiente</strong>
                                                        <% } else { %>
                                                            <strong>
                                                                <%= item.real_home_score %> - <%= item.real_away_score
                                                                        %>
                                                            </strong>
                                                            <% } %>
                                                </div>

                                                <div class="points-result-card">
                                                    <span class="info-title">Puntos obtenidos</span>

                                                    <% if (item.points===null) { %>
                                                        <span class="points-badge pending">-</span>
                                                        <% } else { %>
                                                            <span class="points-badge points-<%= item.points %>">
                                                                <%= item.points %>
                                                            </span>
                                                            <% } %>
                                                </div>

                                            </div>
                                        </article>

                                        <% }) %>
                                </div>

                                <p class="muted community-no-results" style="display:none;">
                                    No se encontraron participantes con ese nombre en este partido.
                                </p>

                                <% } %>
                </div>
            </details>

            <% }) %>
    </div>

    <script>

        document.querySelectorAll(".community-match-card").forEach((card) => {
            card.addEventListener("toggle", () => {
                if (card.open) {
                    document.querySelectorAll(".community-match-card").forEach((otherCard) => {
                        if (otherCard !== card) {
                            otherCard.open = false;
                        }
                    });

                    setTimeout(() => {
                        const y = card.getBoundingClientRect().top + window.scrollY - 90;
                        window.scrollTo({
                            top: y,
                            behavior: "smooth"
                        });
                    }, 100);
                }
            });
        });

    </script>

    <%- include('partials/footer') %>