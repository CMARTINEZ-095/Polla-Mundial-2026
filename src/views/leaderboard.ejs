<%- include('partials/header') %>
  <div class="page-heading">
    <div>
      <p class="eyebrow">Clasificación</p>
      <h1>Tabla de posiciones</h1>
      <p class="muted">
        La tabla se calcula automáticamente con 3 puntos por marcador exacto y 1 punto por acertar ganador o empate.
      </p>
    </div>

    <div class="actions-row">
      <a class="button secondary" href="/predictions">⚽ Mis pronósticos</a>
      <a class="button secondary" href="/public-predictions">👥 Pronósticos de la comunidad</a>

      <% if (currentUser && currentUser.role==='admin' ) { %>
        <a class="button secondary" href="/leaderboard.csv">Descargar CSV</a>
        <% } %>
    </div>
  </div>

  <div class="card table-card leaderboard-table-card-v2">
    <% if (leaderboard.length===0) { %>
      <p class="muted">Todavía no hay participantes registrados.</p>
      <% } else { %>

        <div class="table-wrap leaderboard-scroll-wrap">
          <table class="leaderboard-table leaderboard-table-v2">
            <thead>
              <tr>
                <th>#</th>
                <th>Participante</th>
                <th>Puntos</th>
                <th>Exactos</th>
                <th>Ganador/empate</th>
                <th>Revisados</th>
                <th>Pronósticos</th>
              </tr>
            </thead>
            <tbody>
              <% leaderboard.forEach((player, index)=> {

                const firstName = String(player.name || '')
                .trim()
                .split(' ')[0];

                const displayName =
                firstName.charAt(0).toUpperCase() +
                firstName.slice(1).toLowerCase();

                %>

                <tr
                  class="<%= index === 0 ? 'leader-gold' : index === 1 ? 'leader-silver' : index === 2 ? 'leader-bronze' : '' %>">

                  <td class="leader-position">
                    <% if(index===0){ %>
                      🥇
                      <% } else if(index===1){ %>
                        🥈
                        <% } else if(index===2){ %>
                          🥉
                          <% } else { %>
                            <span class="rank-normal">
                              <%= index + 1 %>
                            </span>
                            <% } %>
                  </td>

                  <td class="leader-name">
                    <%= displayName %>
                  </td>

                  <td class="leader-points">
                    <strong>
                      <%= player.points %>
                    </strong>
                  </td>

                  <td>
                    <span class="mini-badge green">
                      <%= player.exacts %>
                    </span>
                  </td>

                  <td>
                    <span class="mini-badge yellow">
                      <%= player.outcomes || 0 %>
                    </span>
                  </td>

                  <td>
                    <span class="mini-badge blue">
                      <%= player.predictions_checked %>
                    </span>
                  </td>

                  <td>
                    <span class="mini-badge gray">
                      <%= player.total_predictions %>
                    </span>
                  </td>

                </tr>

                <% }) %>
            </tbody>

          </table>
        </div>

        <% } %>
  </div>

  <%- include('partials/footer') %>

  <% 
  const currentRankIndex = currentUser 
    ? leaderboard.findIndex(player => Number(player.id) === Number(currentUser.id))
    : -1;

  const isCurrentUserFirst = currentRankIndex === 0;
%>

<% if (isCurrentUserFirst) { %>
  <div id="leaderWelcomeModal" class="leader-welcome-modal">
    <div class="leader-welcome-card">
      <div class="leader-cup">🏆</div>
      <h2>¡Vas en primer lugar!</h2>
      <p>Estás liderando la Polla Mundial 2026. Sigue así 🔥</p>
      <button type="button" onclick="closeLeaderWelcome()">Continuar</button>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

  <script>
    function closeLeaderWelcome() {
      document.getElementById("leaderWelcomeModal").style.display = "none";
      sessionStorage.setItem("leaderWelcomeShown", "true");
    }

    document.addEventListener("DOMContentLoaded", function () {
      const modal = document.getElementById("leaderWelcomeModal");

      if (sessionStorage.getItem("leaderWelcomeShown") === "true") {
        modal.style.display = "none";
        return;
      }

      confetti({
        particleCount: 180,
        spread: 120,
        origin: { y: 0.6 }
      });

      setTimeout(() => {
        confetti({
          particleCount: 120,
          spread: 90,
          origin: { y: 0.4 }
        });
      }, 800);
    });
  </script>
<% } %>