<%- include('partials/header') %>
  <div class="page-heading">
    <div>
      <p class="eyebrow">Clasificación</p>
      <h1>Tabla de posiciones</h1>
      <p class="muted">
        La tabla se calcula automáticamente con 3 puntos por marcador exacto y 1 punto por acertar ganador o empate.
      </p>
    </div>

    <div class="actions-row">
      <a class="button secondary" href="/predictions">⚽ Mis pronósticos</a>
      <a class="button secondary" href="/public-predictions">👥 Pronósticos de la comunidad</a>

      <% if (currentUser && currentUser.role==='admin' ) { %>
        <a class="button secondary" href="/leaderboard.csv">Descargar CSV</a>
        <% } %>
    </div>
  </div>

  <% const demoPlayers = [
    { name: 'Carlos', points: 10, exacts: 5, outcomes: 6, predictions_checked: 10, total_predictions: 10 },
    { name: 'Laura', points: 9, exacts: 4, outcomes: 5, predictions_checked: 10, total_predictions: 10 },
    { name: 'Mateo', points: 8, exacts: 4, outcomes: 4, predictions_checked: 10, total_predictions: 10 },
    { name: 'Ana', points: 7, exacts: 3, outcomes: 4, predictions_checked: 10, total_predictions: 10 },
    { name: 'Sofía', points: 6, exacts: 3, outcomes: 3, predictions_checked: 10, total_predictions: 10 },
    { name: 'Diego', points: 5, exacts: 2, outcomes: 3, predictions_checked: 10, total_predictions: 10 },
    { name: 'Valentina', points: 4, exacts: 2, outcomes: 2, predictions_checked: 10, total_predictions: 10 },
    { name: 'Julián', points: 3, exacts: 1, outcomes: 2, predictions_checked: 10, total_predictions: 10 },
    { name: 'Paula', points: 2, exacts: 1, outcomes: 1, predictions_checked: 10, total_predictions: 10 },
    { name: 'Andrés', points: 1, exacts: 0, outcomes: 1, predictions_checked: 10, total_predictions: 10 }
  ];

  const leaderboardItems = leaderboard.length >= 10 ? leaderboard : [...leaderboard, ...demoPlayers].slice(0, 10);
  %>

  <div class="card table-card leaderboard-table-card-v2">
    <% if (leaderboardItems.length===0) { %>
      <p class="muted">Todavía no hay participantes registrados.</p>
      <% } else { %>

        <div class="table-wrap leaderboard-scroll-wrap">
          <table class="leaderboard-table leaderboard-table-v2">
            <thead>
              <tr>
                <th>#</th>
                <th>Participante</th>
                <th>Puntos</th>
                <th>Exactos</th>
                <th>Ganador/empate</th>
                <th>Revisados</th>
                <th>Pronósticos</th>
              </tr>
            </thead>
            <tbody>
              <% leaderboardItems.forEach((player, index)=> {

                const firstName = String(player.name || '')
                .trim()
                .split(' ')[0];

                const displayName =
                firstName.charAt(0).toUpperCase() +
                firstName.slice(1).toLowerCase();

                %>

                <tr
                  class="<%= index === 0 ? 'leader-gold' : index === 1 ? 'leader-silver' : index === 2 ? 'leader-bronze' : '' %>">

                  <td class="leader-position">
                    <% if(index===0){ %>
                      🥇
                      <% } else if(index===1){ %>
                        🥈
                        <% } else if(index===2){ %>
                          🥉
                          <% } else { %>
                            <span class="rank-normal">
                              <%= index + 1 %>
                            </span>
                            <% } %>
                  </td>

                  <td class="leader-name">
                    <%= displayName %>
                  </td>

                  <td class="leader-points">
                    <strong>
                      <%= player.points %>
                    </strong>
                  </td>

                  <td>
                    <span class="mini-badge green">
                      <%= player.exacts %>
                    </span>
                  </td>

                  <td>
                    <span class="mini-badge yellow">
                      <%= player.outcomes || 0 %>
                    </span>
                  </td>

                  <td>
                    <span class="mini-badge blue">
                      <%= player.predictions_checked %>
                    </span>
                  </td>

                  <td>
                    <span class="mini-badge gray">
                      <%= player.total_predictions %>
                    </span>
                  </td>

                </tr>

                <% }) %>
            </tbody>

          </table>
        </div>

        <% } %>
  </div>

  <%- include('partials/footer') %>

