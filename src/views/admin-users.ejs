<%- include('partials/header') %>

<div class="page-heading">
  <div>
    <p class="eyebrow">Panel de administrador</p>
    <h1>Usuarios registrados</h1>
    <p class="muted">Desde aquí puedes restablecer o generar una clave temporal para cualquier usuario.</p>
  </div>
</div>

<section class="card users-admin-card">

  <div class="users-card-header">
    <div>
      <h2>Usuarios registrados</h2>
      <span class="users-count"><%= users.length %> usuarios</span>
    </div>
  </div>

  <div class="table-wrap">
    <table class="users-table">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Correo</th>
          <th>Nueva clave</th>
          <th>Acciones</th>
        </tr>
      </thead>

      <tbody>
        <% users.forEach((user)=> { %>
          <tr>
            <td>
              <div class="user-info">
                <div class="user-avatar">
                  <%= formatDisplayName(user.name).charAt(0).toUpperCase() %>
                </div>
                <strong><%= formatDisplayName(user.name) %></strong>
              </div>
            </td>

            <td class="user-email">
              <%= user.email %>
            </td>

            <td>
              <form action="/admin/users/<%= user.id %>/password" method="post" class="user-password-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <input 
                  type="password" 
                  name="new_password" 
                  minlength="6"
                  autocomplete="new-password"
                  placeholder="Nueva clave"
                  required
                  class="new-password-input"
                >

                <button class="btn-save-password" type="submit">
                  Guardar
                </button>
              </form>
            </td>

            <td>
              <% if (user.role !== 'admin') { %>
                <form 
                  action="/admin/users/<%= user.id %>/delete" 
                  method="post" 
                  class="user-delete-form" 
                  onsubmit="return confirm('¿Eliminar este participante y sus pronósticos?');"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                  <button class="btn-delete-user" type="submit">
                    🗑 Eliminar
                  </button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</section>

<%- include('partials/footer') %>