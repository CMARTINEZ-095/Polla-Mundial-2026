<%- include('partials/header') %>

<div class="page-heading">
  <div>
    <p class="eyebrow">Administrador</p>
    <h1>Usuarios registrados</h1>
  </div>
  <a class="button secondary" href="/admin">Volver</a>
</div>

<section class="card table-card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Correo</th>
          <th>Rol</th>
          <th>Creado</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user) => { %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><%= user.role === 'admin' ? 'Administrador' : 'Participante' %></td>
            <td><%= helpers.formatDateTime(user.created_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
