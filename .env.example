# Copia este archivo como .env para desarrollo local.
APP_NAME="Polla Mundial 2026"
PORT=3000
NODE_ENV=development
SESSION_SECRET="cambia-este-secreto-largo"
TIMEZONE="America/Bogota"

# Administrador inicial. Se crea automaticamente si no existe.
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@demo.com"
ADMIN_PASSWORD="admin123"

# Base de datos local por defecto: archivo JSON.
# Render recomendado: define DATABASE_URL con PostgreSQL.
# DATABASE_URL="postgresql://usuario:clave@host:5432/base"
# DATABASE_SSL="false"

# Si usas JSON en Render con disco persistente, apunta DATA_FILE al disco.
# DATA_FILE="/opt/render/project/src/data/db.json"
